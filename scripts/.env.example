# Thermae Scripts — Environment Variables
# Copy this file to scripts/.env and fill in your credentials.
# NEVER commit scripts/.env to git — it is listed in .gitignore.

# Zoho Mail SMTP credentials
# Used by weekly-health-check.js and monitor-new-saunas.js to email reports to hello@thermae.app
ZOHO_EMAIL=hello@thermae.app
ZOHO_PASSWORD=your_zoho_app_password_here

# Google Places API key (optional)
# Used by monitor-new-saunas.js to query Google Places for new venue discovery
# Get yours at: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Anthropic API key (optional)
# Reserved for future AI-assisted venue description generation
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
