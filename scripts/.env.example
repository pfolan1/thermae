# Thermae Scripts — Environment Variables
# Copy this file to scripts/.env and fill in your credentials.
# NEVER commit scripts/.env to git — it is listed in .gitignore.

# Zoho Mail SMTP credentials
# Used by weekly-health-check.js to email the report to hello@thermae.app
ZOHO_EMAIL=hello@thermae.app
ZOHO_PASSWORD=your_zoho_app_password_here
